# Copy this file to ".env" and fill in your own values, then restart the server.
# The app runs fine WITHOUT Stripe (Pro checkout just stays disabled).

# Public origin used to build Stripe success/cancel/return URLs.
APP_URL=http://127.0.0.1:4173

# --- Stripe (optional; only needed for the "Upgrade to Pro" checkout) ---
# 1) Create a recurring Price in your Stripe dashboard -> paste its id here (starts with price_).
# 2) Get your Secret key from Stripe -> Developers -> API keys (starts with sk_test_ or sk_live_).
# 3) Create a webhook endpoint pointing at  <APP_URL>/api/billing/webhook
#    subscribed to: checkout.session.completed, customer.subscription.updated,
#    customer.subscription.deleted  -> paste its signing secret here (starts with whsec_).
STRIPE_PRICE_ID=price_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Admin login seeded on first run ---
ORKXTRA_ADMIN_EMAIL=admin@example.com
ORKXTRA_ADMIN_PASSWORD=change-me-please
ORKXTRA_ADMIN_NAME=ORKXTRA Admin
